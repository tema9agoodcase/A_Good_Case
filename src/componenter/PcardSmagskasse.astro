---
const {product} = Astro.props;
---
<a href={`/smagskassedetalje/${product.id}`} class="card-link">
  <article>
      <img src={product.Billede} alt="productimage">
      <p class="bestbefore">Best before {product["Bedst før"]}</p>
      <hr class="linje">
      <h3>{product.Navn}</h3>
      <p class="price">{product.Pris}</p>
  </article>
</a>

<style>
.card-link {
  text-decoration: none;
  color: inherit;
}
.bestbefore{text-align: center;}
.price { margin-top: auto;}
.linje {
  border: none;
  height: 2px;
  background-color: #BFB59F;
}
article {
  padding: 1rem;
  max-width: 450px;
  margin: 20px;
  display: flex;
  flex-direction: column;
}
article:hover {
  box-shadow: 0 8px 20px rgba(0,0,0,0.15);
}
img {
  width: 200px;
}


@media (max-width: 800px) {
    article {
    margin: 0;
}

}

</style>
---
const { tekst } = Astro.props;
---
<!-- Knappen på billedernes forside -->

<button class="forside_knap">
  {tekst}
</button>


<style>
   .forside_knap {
    padding: 12px 100px;
    border: solid #198A2E;
    background: #198A2E;
    color: #FFFDFB;
    font-size: 18px;
    font-weight: bold;
  }

  .forside_knap:hover{
  background: #FFFDFB;
    color:#198A2E;
    border: solid #198A2E;
  }

    @media (max-width: 800px) {
    .btn{
        padding: 5px 45px;
        font-size: 11px;
        font-weight: bold;
    }
  }

</style>
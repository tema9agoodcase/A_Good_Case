---
const {product} = Astro.props;
---
<a href={`/beersdetalje/${product.id}`} class="Pcard" data-type={product.Type}>
<article>
    <img src={product.img} alt="productimage">
    <p class="bestbefore">Best before {product.bestbefore}</p>
    <hr class="linje">
    <h3>{product.name}</h3>
    <p class="price">{product.price} kr pr. stk</p>
</article>
</a>
<style>
    a {text-decoration: none;
    color: #392F1C;}
.bestbefore{text-align: center;}
.price { margin-top: auto;}
.linje {
  border: none;
  height: 2px;
  background-color: #BFB59F;
}
article {
    padding: 1rem;
    max-width: 450px;
    margin: 20px;
    display: flex;
    flex-direction: column;
}
article:hover {
  box-shadow: 0 8px 20px rgba(0,0,0,0.15);
}
img {
    display: flex;
    justify-content: center;
    width: 200px;
}
.hide {display: none;}
</style>
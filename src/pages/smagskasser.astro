---
import Layout from "../layout/Layout.astro";
import PcardSmagskasse from "../componenter/PcardSmagskasse.astro";
import MovingBanner2 from "../componenter/Moving_banner_2.astro";
const endpoint = "https://etarsiqlcxhzhbbnkvuv.supabase.co/rest/v1/Smagskasser?select=*";

const options={
    headers:{
        apikey: "sb_publishable_EnRm-UFeqtEtlMUvBcCH4g_4zaC8eAa",
        Authorization: "Bearer sb_publishable_EnRm-UFeqtEtlMUvBcCH4g_4zaC8eAa",
    },
};

const data = await fetch(endpoint, options)
  .then((response) => response.json());
---

<Layout>
    <MovingBanner2/>
    <img class="img_icon" src="/img/icon.svg" alt="Genbrug ikon" />
    <h1>Smagskasser</h1>
    <section>
        {data.map((product) => (<PcardSmagskasse {product}/>))}
    </section>
</Layout>

<style>
.img_icon {margin: 30px;}

.filtrer {margin: 30px;
margin-left: 100px;
display: flex;}

.img_filtrer {margin: 10px;}

h1 {text-align: center;}
section 
{display: grid;
grid-template-columns: repeat(5, 1fr);
max-width: 1450px;}

@media (max-width: 800px){
   section {    
    display: grid;
grid-template-columns: repeat(2, 1fr);}
  
#buttons button {
   min-width: 60px;
}
}
</style>